<?xml version="1.0"?>

<robot name="simple_robot">

  <!-- ================= BASE ================= -->

  <link name="base_link">

    <visual>
      <geometry>
        <box size="0.5 0.3 0.2"/>
      </geometry>

      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>

  </link>

  <!-- ================= LEFT WHEEL ================= -->

  <link name="left_wheel">

    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>

      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>

      <!-- Поворачиваем колесо -->
      <origin rpy="1.5707 0 0"/>

    </visual>

  </link>

  <!-- ================= RIGHT WHEEL ================= -->

  <link name="right_wheel">

    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>

      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>

      <origin rpy="1.5707 0 0"/>

    </visual>

  </link>

  <!-- ================= LEFT JOINT ================= -->

  <joint name="left_wheel_joint" type="continuous">

    <parent link="base_link"/>
    <child link="left_wheel"/>

    <!-- x y z -->
    <origin xyz="0 0.15 -0.05"/>

    <axis xyz="0 1 0"/>

  </joint>

  <!-- ================= RIGHT JOINT ================= -->

  <joint name="right_wheel_joint" type="continuous">

    <parent link="base_link"/>
    <child link="right_wheel"/>

    <origin xyz="0 -0.15 -0.05"/>

    <axis xyz="0 1 0"/>

  </joint>

</robot>
